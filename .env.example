# Copy to `.env` locally (never commit `.env`). In Vercel: Project → Settings → Environment Variables.

# Neon Postgres — paste your full connection string from the Neon dashboard.
# Format: postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/neondb?sslmode=require"

# Google account used to sign in to Neon (for your team’s reference only; not used by the app)
NEON_ACCOUNT_EMAIL="privekian8@gmail.com"

# NextAuth (set in Vercel for production)
# Production site: use the canonical URL with no trailing slash, e.g. https://www.kianprive.com
# NEXTAUTH_URL="https://www.kianprive.com"
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32-or-node-crypto"

# Acuity Scheduling (Integrations → API in Acuity dashboard)
# ACUITY_USER_ID="your_numeric_user_id"
# ACUITY_API_KEY="your_api_key"
# ACUITY_SCHEDULER_BASE_URL="https://YourBusiness.as.me"
# ACUITY_SCHEDULING_ENABLED="true"
# ACUITY_BOOK_AS_ADMIN="true"
# Optional per-service overrides: ACUITY_TYPE_NUTRITION=19112766
